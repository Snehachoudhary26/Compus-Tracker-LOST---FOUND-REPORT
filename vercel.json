{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/uploads/(.*)", "dest": "backend/server.js" },
    { "src": "/frontend/(.*)", "dest": "frontend/$1" },
    { "src": "/", "dest": "frontend/index.html" },
    { "src": "/(.*\\.html)", "dest": "frontend/$1" },
    { "src": "/(.*\\.js)", "dest": "frontend/$1" },
    { "src": "/(.*\\.json)", "dest": "frontend/$1" },
    { "src": "/(.*\\.css)", "dest": "frontend/$1" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
